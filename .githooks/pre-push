#!/usr/bin/env bash
set -euo pipefail

echo "🔍 Pre-push checks..."

# Fast PHP syntax check on changed files
REMOTE="${1:-origin}"
REMOTE_SHA=$(git rev-parse "$REMOTE/main" 2>/dev/null || echo "HEAD~5")
CHANGED_PHP=$(git diff --name-only "$REMOTE_SHA"...HEAD -- '*.php' 2>/dev/null || true)

if [ -n "$CHANGED_PHP" ]; then
    echo "Checking PHP syntax on changed files..."
    echo "$CHANGED_PHP" | while read -r file; do
        if [ -f "$file" ]; then
            php -l "$file" > /dev/null 2>&1 || {
                echo "❌ Syntax error in $file"
                exit 1
            }
        fi
    done
    echo "✅ PHP syntax OK"
fi

# Validate composer.json
echo "Validating composer.json..."
composer validate --no-check-all --no-check-publish > /dev/null 2>&1 || {
    echo "❌ composer.json validation failed"
    exit 1
}
echo "✅ composer.json valid"

# Run PHPStan if available
if composer run-script --list 2>/dev/null | grep -q phpstan; then
    echo "Running PHPStan..."
    composer phpstan 2>&1 || {
        echo "❌ PHPStan failed"
        exit 1
    }
    echo "✅ PHPStan passed"
fi

echo "✅ All pre-push checks passed"
